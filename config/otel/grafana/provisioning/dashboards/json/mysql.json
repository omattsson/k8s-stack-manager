{
  "uid": "mysql-overview",
  "title": "MySQL Overview",
  "tags": [
    "mysql",
    "database"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "schemaVersion": 39,
  "version": 2,
  "editable": true,
  "panels": [
    {
      "type": "row",
      "title": "App Connection Pool (OTel Metrics)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Connection Pool",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Max Open"
            },
            "properties": [
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              },
              {
                "id": "custom.fillOpacity",
                "value": 0
              },
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "red"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "db_pool_open",
          "legendFormat": "Open",
          "refId": "A"
        },
        {
          "expr": "db_pool_in_use",
          "legendFormat": "In Use",
          "refId": "B"
        },
        {
          "expr": "db_pool_idle",
          "legendFormat": "Idle",
          "refId": "C"
        },
        {
          "expr": "db_pool_max_open",
          "legendFormat": "Max Open",
          "refId": "D"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Pool Wait Count (rate)",
